<launch>
  <node pkg="deck_interface_ros1" type="deck_truth_bridge.py" name="deck_truth_bridge" output="screen">
    <param name="world_frame" value="world"/>
    <param name="deck_frame" value="deck_frame"/>
    <param name="landing_target_frame" value="landing_target_frame"/>
    <param name="uav_frame" value="uav_base_link"/>
    <param name="wamv_model" value="wamv"/>
    <param name="uav_model" value="iris_0"/>
    <rosparam param="deck_offset_xyz">[0.0, 0.0, 1.25]</rosparam>
    <rosparam param="landing_target_offset_xyz">[0.5, 0.0, 1.25]</rosparam>
  </node>
</launch>
